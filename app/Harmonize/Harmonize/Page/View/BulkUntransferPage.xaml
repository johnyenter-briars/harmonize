<?xml version="1.0" encoding="utf-8" ?>
<pages:BasePage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:Harmonize.Page"
    xmlns:viewModels="clr-namespace:Harmonize.ViewModel"
    xmlns:model="clr-namespace:Harmonize.Model"
    x:TypeArguments="viewModels:BulkUntransferViewModel"
    x:DataType="viewModels:BulkUntransferViewModel"
    x:Class="Harmonize.Page.View.BulkUntransferPage"
    Title="Bulk Untransfer">

    <Grid
        Padding="10"
        RowDefinitions="Auto,*,Auto"
        BackgroundColor="{StaticResource Gray900}">

        <Border
            Grid.Row="0"
            BackgroundColor="{StaticResource Gray600}"
            Padding="14"
            Margin="0,0,0,10"
            Stroke="{StaticResource Gray500}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="14" />
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="12">
                <Label
                    Text="Choose the transferred files you want to untransfer."
                    FontSize="18"
                    TextColor="{StaticResource OffWhite}" />

                <Label
                    Text="Nothing is pre-selected. Use Select All if you want the full list."
                    FontSize="13"
                    TextColor="{StaticResource Gray200}" />

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button
                        Grid.Column="0"
                        Text="Select All"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource Black}"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        HeightRequest="46"
                        IsEnabled="{Binding HasEntriesAndNotSubmitting}"
                        Command="{Binding SelectAllCommand}" />

                    <Button
                        Grid.Column="1"
                        Text="Clear"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource Primary}"
                        BorderColor="{StaticResource Primary}"
                        BorderWidth="1"
                        CornerRadius="12"
                        HeightRequest="46"
                        IsEnabled="{Binding HasEntriesAndNotSubmitting}"
                        Command="{Binding ClearSelectionCommand}" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <Grid Grid.Row="1">
            <CollectionView
                ItemsSource="{Binding Entries}"
                IsVisible="{Binding NotFetchingData}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:SelectableMediaEntry">
                        <Border
                            Margin="0,0,0,10"
                            Padding="14,12"
                            BackgroundColor="{StaticResource Gray600}"
                            Stroke="{StaticResource Gray500}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>

                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource SecondaryDark}" />
                                    <Setter Property="Stroke" Value="{StaticResource Primary}" />
                                </DataTrigger>
                            </Border.Triggers>

                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:BulkUntransferViewModel}}, Path=ToggleSelectionCommand}"
                                        CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>

                                <CheckBox
                                    Grid.Column="0"
                                    VerticalOptions="Center"
                                    Color="{StaticResource Primary}"
                                    IsChecked="{Binding IsSelected, Mode=TwoWay}" />

                                <Label
                                    Grid.Column="1"
                                    Text="{Binding Name}"
                                    FontSize="15"
                                    VerticalOptions="Center"
                                    TextColor="{StaticResource OffWhite}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <VerticalStackLayout
                IsVisible="{Binding FetchingData}"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Spacing="12">
                <ActivityIndicator
                    IsRunning="{Binding FetchingData}"
                    Color="{StaticResource Primary}"
                    WidthRequest="42"
                    HeightRequest="42" />
                <Label
                    Text="Loading transferred files..."
                    TextColor="{StaticResource Gray200}" />
            </VerticalStackLayout>

            <VerticalStackLayout
                VerticalOptions="Center"
                HorizontalOptions="Center"
                Spacing="8">
                <VerticalStackLayout.Triggers>
                    <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding HasEntries}" Value="True">
                        <Setter Property="IsVisible" Value="False" />
                    </DataTrigger>
                    <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding FetchingData}" Value="True">
                        <Setter Property="IsVisible" Value="False" />
                    </DataTrigger>
                </VerticalStackLayout.Triggers>
                <Label
                    Text="No transferred files found."
                    TextColor="{StaticResource Gray200}"
                    FontSize="16" />
            </VerticalStackLayout>
        </Grid>

        <Border
            Grid.Row="2"
            BackgroundColor="{StaticResource Gray600}"
            Padding="14"
            Margin="0,10,0,0"
            Stroke="{StaticResource Gray500}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="14" />
            </Border.StrokeShape>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                    <Label
                        Text="Ready to submit"
                        FontSize="13"
                        TextColor="{StaticResource Gray200}" />
                    <Label
                        Text="{Binding SelectedCountText}"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="{StaticResource OffWhite}" />
                </VerticalStackLayout>

                <Grid Grid.Column="1" VerticalOptions="Center">
                    <Button
                        Text="{Binding SubmitButtonText}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="{StaticResource Black}"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        HeightRequest="48"
                        WidthRequest="150"
                        IsEnabled="{Binding CanSubmit}"
                        Command="{Binding SubmitCommand}" />

                    <ActivityIndicator
                        IsVisible="{Binding IsSubmitting}"
                        IsRunning="{Binding IsSubmitting}"
                        Color="{StaticResource Black}"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</pages:BasePage>
